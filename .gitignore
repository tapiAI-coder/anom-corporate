# ============================================
# ANOM コーポレートサイト .gitignore
# リポジトリに含めないファイルの一覧
# ============================================

# 旧Astro時代のビルド残骸（archive/astro-v3 ブランチに本体は保存済み）
node_modules/
dist/
.astro/

# デザイン素材の原本（OneDrive上で管理。サイズが大きいためgitに入れない）
anom web素材/

# 確認用スクリーンショット（その都度生成するもの）
screenshots/

# 環境変数ファイル（秘密情報。絶対にコミットしない）
.env
.env.*

# OSが自動生成するファイル
.DS_Store
Thumbs.db

# エディタ設定
.vscode/
.idea/

# 改修作業用のローカルバックアップ（公開しない）
index_bak.html

# Claude Code のローカル開発設定（公開不要）
.claude/
