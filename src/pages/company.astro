---
// 会社概要ページ — テーブル形式の基本情報
import BaseLayout from "../layouts/BaseLayout.astro";
import CTASection from "../components/CTASection.astro";
import { companyInfo } from "../data/company";
---

<BaseLayout
  title="会社概要"
  description="ANOM（アノム）の会社概要。秋田県を拠点に、中小企業のDX・AI導入を支援するコンサルティング会社です。"
>
  <!-- ページヘッダー -->
  <section class="bg-gradient-to-br from-navy to-dark px-4 pt-32 pb-16 md:pt-40 md:pb-20">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-xs tracking-[0.2em] font-semibold text-white/50 uppercase">
        Company
      </p>
      <h1 class="mt-4 text-3xl font-bold text-white md:text-4xl">
        会社概要
      </h1>
    </div>
  </section>

  <!-- 会社情報テーブル -->
  <section class="px-4 py-16 md:py-24">
    <div class="mx-auto max-w-3xl">
      <div class="overflow-hidden rounded-lg border border-border">
        <table class="w-full">
          <tbody>
            {companyInfo.map((item, index) => (
              <tr class:list={[index !== 0 && "border-t border-border"]}>
                <th class="w-1/3 bg-bg-alt px-4 py-4 text-left text-sm font-semibold text-dark md:w-1/4 md:px-8 md:py-5">
                  {item.label}
                </th>
                <td class="px-4 py-4 text-sm text-dark md:px-8 md:py-5">
                  {"isLink" in item && item.isLink ? (
                    <a
                      href={item.value}
                      class="text-navy underline transition-colors hover:text-navy-light"
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      {item.value}
                    </a>
                  ) : (
                    item.value
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <!-- ミッション補足 -->
      <div class="mt-12 rounded-lg border border-border bg-bg-alt p-6 md:p-8">
        <h2 class="text-base font-bold text-dark">ANOMについて</h2>
        <p class="mt-3 text-sm leading-relaxed text-sub">
          ANOM（アノム）は「Autonomous + Minimalism」を掲げ、
          秋田の中小企業の無駄をなくし、AI導入で定型業務を削減することをミッションとしています。
          削減で生まれた能力・人・時間を適材適所に割り振り、売上向上につなげる。
          秋田と関東の差をなくす ── それがANOMの存在意義です。
        </p>
      </div>
    </div>
  </section>

  <!-- CTAセクション -->
  <CTASection />
</BaseLayout>
