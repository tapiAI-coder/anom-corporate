---
// サービス紹介ページ — 各サービス詳細 + 支援の流れ
import BaseLayout from "../layouts/BaseLayout.astro";
import CTASection from "../components/CTASection.astro";
import { services, flowSteps } from "../data/services";
---

<BaseLayout
  title="サービス紹介"
  description="ANOMが提供するDX・AI導入支援サービスの詳細。アドバイザリー、DX・AI診断、業務フロー改善、AI導入支援、ツール選定・導入後サポート。"
>
  <!-- ページヘッダー — 幾何学装飾付き -->
  <section class="relative overflow-hidden bg-gradient-to-br from-navy via-navy-dark to-dark px-4 pt-32 pb-16 md:pt-40 md:pb-24">
    <!-- 背景の幾何学装飾 -->
    <div class="pointer-events-none absolute inset-0" aria-hidden="true">
      <div class="absolute -top-20 -right-20 h-80 w-80 rounded-full border border-white/5"></div>
      <div class="absolute -bottom-10 -left-10 h-60 w-60 rotate-45 border border-white/5"></div>
      <div class="absolute top-1/3 right-1/4 h-2 w-2 rounded-full bg-white/20"></div>
      <div class="absolute bottom-1/4 left-1/3 h-1.5 w-1.5 rounded-full bg-white/15"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-dark/30 via-transparent to-transparent"></div>
    </div>

    <div class="relative mx-auto max-w-3xl text-center">
      <p class="text-xs tracking-[0.3em] font-semibold text-white/40 uppercase">
        Services
      </p>
      <h1 class="mt-4 text-3xl font-bold tracking-tight text-white md:text-5xl">
        サービス紹介
      </h1>
      <p class="mt-6 text-base leading-relaxed text-white/60 md:text-lg">
        戦略立案から導入・定着まで、一気通貫で支援します。
      </p>
    </div>
  </section>

  <!-- サービス詳細一覧 -->
  <section class="px-4 py-20 md:py-28">
    <div class="mx-auto max-w-5xl space-y-12 md:space-y-16">
      {services.map((service, index) => (
        <div class="service-card group relative overflow-hidden rounded-2xl border border-border bg-white p-8 shadow-sm transition-all duration-500 hover:border-navy/20 hover:shadow-xl md:p-10">
          {/* 背景のアクセント装飾 */}
          <div class="pointer-events-none absolute -right-16 -top-16 h-48 w-48 rounded-full bg-gradient-to-br from-navy/5 to-transparent transition-transform duration-500 group-hover:scale-150"></div>
          <div class="pointer-events-none absolute -left-8 -bottom-8 h-32 w-32 rotate-45 border border-navy/5 transition-transform duration-500 group-hover:rotate-[60deg]"></div>

          <div class="relative flex flex-col gap-6 md:flex-row md:items-start md:gap-10">
            {/* アイコン — グラデーション背景 */}
            <div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-navy to-navy-dark shadow-lg shadow-navy/20 transition-transform duration-300 group-hover:scale-110 md:h-20 md:w-20">
              <svg
                class="h-8 w-8 text-white md:h-10 md:w-10"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="1.5"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d={service.icon} />
              </svg>
            </div>

            {/* テキスト */}
            <div class="flex-1">
              {/* サービス番号 + タイトル */}
              <div class="flex items-center gap-3">
                <span class="text-xs font-bold tracking-wider text-navy/40">
                  {String(index + 1).padStart(2, "0")}
                </span>
                <h2 class="text-xl font-bold text-dark md:text-2xl">
                  {service.title}
                </h2>
              </div>

              {/* 区切り線（グラデーション） */}
              <div class="mt-4 h-px w-16 bg-gradient-to-r from-navy to-navy-light transition-all duration-500 group-hover:w-24"></div>

              <p class="mt-5 text-base leading-relaxed text-sub">
                {service.description}
              </p>

              {/* こんな方におすすめ — カード風 */}
              <div class="mt-8 rounded-xl border border-navy/10 bg-gradient-to-br from-bg to-bg-alt p-6">
                <p class="flex items-center gap-2 text-sm font-bold text-navy">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                  </svg>
                  こんな方におすすめ
                </p>
                <ul class="mt-4 space-y-3">
                  {service.recommended.map((item) => (
                    <li class="flex items-start gap-3 text-sm leading-relaxed text-sub">
                      <span class="mt-1.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-navy/10">
                        <svg class="h-3 w-3 text-navy" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                        </svg>
                      </span>
                      {item}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- 支援の流れ — ダーク背景で印象的に -->
  <section class="relative overflow-hidden bg-gradient-to-br from-navy via-navy-dark to-dark px-4 py-20 md:py-28">
    <!-- 背景装飾 -->
    <div class="pointer-events-none absolute inset-0" aria-hidden="true">
      <div class="absolute top-1/4 -right-20 h-96 w-96 rounded-full border border-white/5"></div>
      <div class="absolute -bottom-20 left-1/4 h-64 w-64 rotate-12 border border-white/5"></div>
    </div>

    <div class="relative mx-auto max-w-4xl">
      <!-- セクションヘッダー -->
      <div class="text-center">
        <p class="text-xs tracking-[0.3em] font-semibold text-white/40 uppercase">
          Flow
        </p>
        <h2 class="mt-4 text-2xl font-bold tracking-tight text-white md:text-3xl">
          支援の流れ
        </h2>
        <p class="mt-4 text-base text-white/50">
          ヒアリングから定着まで、5つのステップで伴走します。
        </p>
      </div>

      <!-- フローステップ — カード型 -->
      <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-5">
        {flowSteps.map((step, index) => (
          <div class="flow-card group relative">
            {/* 矢印コネクター（PC: 横、タブレット以下: 非表示） */}
            {index < flowSteps.length - 1 && (
              <div class="pointer-events-none absolute -right-3 top-1/2 z-10 hidden -translate-y-1/2 lg:block">
                <svg class="h-4 w-4 text-white/20" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6z" />
                </svg>
              </div>
            )}

            <div class="flex h-full flex-col items-center rounded-xl border border-white/10 bg-white/5 p-6 text-center backdrop-blur-sm transition-all duration-300 hover:border-white/25 hover:bg-white/10">
              {/* ステップ番号 */}
              <div class="flex h-12 w-12 items-center justify-center rounded-full bg-gradient-to-br from-white/20 to-white/5 text-lg font-bold text-white ring-1 ring-white/20">
                {step.step}
              </div>

              {/* タイトル */}
              <h3 class="mt-4 text-base font-bold text-white">
                {step.title}
              </h3>

              {/* 区切り */}
              <div class="mx-auto mt-3 h-px w-8 bg-gradient-to-r from-transparent via-white/30 to-transparent"></div>

              {/* 説明 */}
              <p class="mt-3 text-xs leading-relaxed text-white/50">
                {step.description}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTAセクション -->
  <CTASection />
</BaseLayout>
