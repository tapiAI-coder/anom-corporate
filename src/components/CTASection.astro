---
// 問い合わせ誘導セクション（全ページ共通で使用）
import { withBase } from "../data/navigation";

interface Props {
  /** 見出しテキスト */
  heading?: string;
  /** 説明テキスト */
  description?: string;
}

const {
  heading = "まずは無料でご相談ください",
  description = "DX・AI導入に関するお悩み、業務効率化のご相談など、お気軽にお問い合わせください。",
} = Astro.props;
---

<section class="relative overflow-hidden bg-gradient-to-br from-navy via-navy-dark to-dark px-4 py-24 md:py-32">
  <!-- 背景装飾 -->
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div class="absolute -top-24 -right-24 h-80 w-80 rounded-full border border-white/5"></div>
    <div class="absolute -bottom-16 -left-16 h-64 w-64 rotate-45 border border-white/5"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 h-[500px] w-[500px] rounded-full bg-navy-light/5 blur-[100px]"></div>
  </div>

  <div class="relative mx-auto max-w-2xl text-center">
    <!-- ラベル -->
    <p class="text-xs tracking-[0.3em] font-semibold text-white/30 uppercase">
      Contact
    </p>

    <!-- 見出し -->
    <h2 class="mt-4 text-2xl font-bold tracking-tight text-white md:text-4xl">
      {heading}
    </h2>

    <!-- 区切り線 -->
    <div class="mx-auto mt-6 h-px w-16 bg-gradient-to-r from-transparent via-white/30 to-transparent"></div>

    <!-- 説明 -->
    <p class="mt-6 text-base leading-relaxed text-white/50 md:text-lg">
      {description}
    </p>

    <!-- CTAボタン群 -->
    <div class="mt-12 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <!-- お問い合わせフォームボタン -->
      <a
        href={withBase("/contact")}
        class="group relative inline-flex items-center gap-2 rounded-lg bg-white px-8 py-4 text-sm font-semibold text-navy shadow-lg shadow-white/10 transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_12px_40px_rgba(255,255,255,0.2)]"
      >
        お問い合わせ
        <svg class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
        <span class="absolute inset-0 -z-10 rounded-lg bg-white opacity-0 blur-2xl transition-opacity duration-300 group-hover:opacity-25"></span>
      </a>

      <!-- LINE友だち追加ボタン（URLは後で設定） -->
      <a
        href="#"
        class="group inline-flex items-center gap-2 rounded-lg border border-white/20 px-8 py-4 text-sm font-semibold text-white/70 backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:border-white/40 hover:text-white hover:bg-white/5"
      >
        LINEで相談する
        <svg class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</section>
