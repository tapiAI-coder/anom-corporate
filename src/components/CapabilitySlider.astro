---
// 対応領域スライダー — 横スクロール式カルーセル
// CSS scroll-snap + 軽量JSによる矢印ボタンナビゲーション
import { capabilities } from "../data/capabilities";
---

<div class="capability-slider relative">
  <!-- カルーセル本体 -->
  <div
    class="capability-track -mx-4 flex snap-x snap-mandatory gap-4 overflow-x-auto scroll-smooth px-4 pb-4 md:gap-6 md:px-8"
    role="region"
    aria-label="ANOMが対応する領域"
  >
    {capabilities.map((cap, index) => (
      <article class="capability-card glass-card glow-hover group relative flex min-h-[340px] w-[85%] shrink-0 snap-start flex-col overflow-hidden p-7 sm:w-[380px] md:min-h-[360px] md:p-8">
        <!-- アブストラクト背景装飾 -->
        <div class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
          <div class="absolute -right-16 -top-16 h-40 w-40 rounded-full bg-accent/[0.06] blur-3xl transition-all duration-500 group-hover:bg-accent/[0.10]"></div>
          <div class="absolute -bottom-12 -left-12 h-32 w-32 rounded-full border border-white/[0.04]"></div>
        </div>

        <!-- 上部: カテゴリラベル + 番号 -->
        <div class="flex items-start justify-between">
          <span class="text-[10px] tracking-[0.25em] font-semibold text-white/40 uppercase">
            {cap.category}
          </span>
          <span class="text-xs font-bold tracking-wider text-white/[0.10]">
            {String(index + 1).padStart(2, "0")} / {String(capabilities.length).padStart(2, "0")}
          </span>
        </div>

        <!-- アイコン -->
        <div class="mt-8 flex h-14 w-14 items-center justify-center rounded-xl border border-white/[0.08] bg-white/[0.06]">
          <svg
            class="h-7 w-7 text-white/70"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d={cap.icon} />
          </svg>
        </div>

        <!-- タイトル -->
        <h3 class="mt-5 text-base font-bold leading-snug text-white md:text-lg">
          {cap.title}
        </h3>

        <!-- 区切り線 -->
        <div class="mt-3 h-px w-10 bg-gradient-to-r from-transparent via-white/20 to-transparent"></div>

        <!-- 説明 -->
        <p class="mt-4 text-sm leading-loose text-white/60">
          {cap.description}
        </p>
      </article>
    ))}
    <!-- 右端の余白（スクロール末尾でもカードが切れないように） -->
    <div class="w-1 shrink-0" aria-hidden="true"></div>
  </div>

  <!-- ナビゲーション — 矢印 + インジケーター -->
  <div class="mt-8 flex items-center justify-between gap-4">
    <!-- ドットインジケーター -->
    <div class="capability-dots flex items-center gap-1.5" role="tablist" aria-label="スライド選択">
      {capabilities.map((_, index) => (
        <button
          type="button"
          class="capability-dot h-1.5 w-1.5 rounded-full bg-white/20 transition-all duration-300 hover:bg-white/40 aria-[current=true]:w-6 aria-[current=true]:bg-white/70"
          data-dot-index={index}
          aria-label={`スライド${index + 1}へ`}
        ></button>
      ))}
    </div>

    <!-- 矢印ボタン -->
    <div class="flex items-center gap-2">
      <button
        type="button"
        class="capability-prev group flex h-10 w-10 items-center justify-center rounded-full border border-white/10 text-white/60 transition-all duration-300 hover:border-white/25 hover:text-white hover:shadow-[0_0_20px_rgba(99,102,241,0.08)] disabled:opacity-30 disabled:cursor-not-allowed disabled:hover:border-white/10 disabled:hover:text-white/60 disabled:hover:shadow-none"
        aria-label="前のスライド"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
      </button>
      <button
        type="button"
        class="capability-next group flex h-10 w-10 items-center justify-center rounded-full border border-white/10 text-white/60 transition-all duration-300 hover:border-white/25 hover:text-white hover:shadow-[0_0_20px_rgba(99,102,241,0.08)] disabled:opacity-30 disabled:cursor-not-allowed disabled:hover:border-white/10 disabled:hover:text-white/60 disabled:hover:shadow-none"
        aria-label="次のスライド"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </button>
    </div>
  </div>
</div>

<style>
  /* カスタムスクロールバー非表示（カルーセルはボタン/ドラッグで操作） */
  .capability-track {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .capability-track::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  // カルーセル操作ロジック
  document.querySelectorAll<HTMLElement>(".capability-slider").forEach((slider) => {
    const track = slider.querySelector<HTMLElement>(".capability-track");
    const prevBtn = slider.querySelector<HTMLButtonElement>(".capability-prev");
    const nextBtn = slider.querySelector<HTMLButtonElement>(".capability-next");
    const dots = Array.from(slider.querySelectorAll<HTMLButtonElement>(".capability-dot"));
    const cards = Array.from(slider.querySelectorAll<HTMLElement>(".capability-card"));

    if (!track || !prevBtn || !nextBtn || cards.length === 0) return;

    const getStep = (): number => {
      const first = cards[0];
      const second = cards[1];
      if (!first) return 300;
      // カード幅 + gap
      const cardWidth = first.getBoundingClientRect().width;
      const gap = second
        ? second.getBoundingClientRect().left - first.getBoundingClientRect().right
        : 16;
      return cardWidth + gap;
    };

    const updateState = () => {
      const step = getStep();
      const current = Math.round(track.scrollLeft / step);
      dots.forEach((dot, i) => {
        if (i === current) dot.setAttribute("aria-current", "true");
        else dot.removeAttribute("aria-current");
      });
      // 端で矢印を無効化
      prevBtn.disabled = track.scrollLeft <= 2;
      nextBtn.disabled =
        track.scrollLeft + track.clientWidth >= track.scrollWidth - 2;
    };

    prevBtn.addEventListener("click", () => {
      track.scrollBy({ left: -getStep(), behavior: "smooth" });
    });
    nextBtn.addEventListener("click", () => {
      track.scrollBy({ left: getStep(), behavior: "smooth" });
    });

    dots.forEach((dot, i) => {
      dot.addEventListener("click", () => {
        track.scrollTo({ left: i * getStep(), behavior: "smooth" });
      });
    });

    let scrollTimer: number | undefined;
    track.addEventListener("scroll", () => {
      if (scrollTimer !== undefined) window.clearTimeout(scrollTimer);
      scrollTimer = window.setTimeout(updateState, 80);
    });

    // 初期状態
    updateState();
    window.addEventListener("resize", updateState);
  });
</script>
