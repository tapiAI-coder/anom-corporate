---
// サービスカード — グラスモーフィズム + glow hover
interface Props {
  title: string;
  summary: string;
  /** SVGアイコンのパスデータ（d属性の値） */
  icon: string;
  /** カード番号（01〜05表示用） */
  index?: number;
  /** カードサイズ（Bento Grid用） */
  size?: "default" | "featured";
}

const { title, summary, icon, index = 0, size = "default" } = Astro.props;
const isFeatured = size === "featured";
---

<div class:list={[
  "glass-card glow-hover group overflow-hidden h-full",
  isFeatured ? "p-8 md:p-10 flex flex-col justify-between" : "p-6 md:p-8",
]}>
  <!-- 上部: 番号 + アイコン -->
  <div class="relative flex items-start justify-between">
    <!-- アイコン — モノトーン -->
    <div class:list={[
      "flex items-center justify-center rounded-xl border border-white/[0.08] bg-white/[0.06]",
      isFeatured ? "h-16 w-16" : "h-14 w-14",
    ]}>
      <svg
        class:list={[
          "text-white/70",
          isFeatured ? "h-8 w-8" : "h-7 w-7",
        ]}
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="1.5"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d={icon} />
      </svg>
    </div>

    <!-- 番号 -->
    <span class:list={[
      "font-bold text-white/[0.05] transition-colors duration-300 group-hover:text-white/[0.10]",
      isFeatured ? "text-5xl" : "text-3xl",
    ]}>
      {String(index + 1).padStart(2, "0")}
    </span>
  </div>

  <!-- タイトル -->
  <h3 class:list={[
    "relative font-bold text-white",
    isFeatured ? "mt-6 text-xl md:text-2xl" : "mt-5 text-lg",
  ]}>
    {title}
  </h3>

  <!-- 区切り線 -->
  <div class="mt-3 h-px w-10 bg-gradient-to-r from-transparent via-white/20 to-transparent"></div>

  <!-- 説明 -->
  <p class:list={[
    "relative leading-relaxed text-white/60",
    isFeatured ? "mt-5 text-base" : "mt-4 text-sm",
  ]}>
    {summary}
  </p>
</div>
