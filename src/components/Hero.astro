---
// ヒーローセクション — 夜から朝へのscrolltelling（Canvas + 4幕構成 + 文字単位リッチ演出）
import { withBase } from "../data/navigation";

const logoSymbol = withBase("/images/logo-symbol.png");
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// 各幕の見出しテキスト（行ごとに分けて span 化）
const acts = [
  {
    id: "panel-1",
    label: "CURRENT STATE",
    headingLines: ["秋田の中小企業は今、", "岐路に立っている。"],
    sub: "手作業、属人化、情報の分断。\n本来の力を発揮できていない。",
  },
  {
    id: "panel-2",
    label: "THE TURNING POINT",
    headingLines: ["AIは、夜明けを", "もたらすことができる。"],
    sub: "定型業務の自動化。情報の一元化。\n変化は、小さな一歩から始まる。",
  },
  {
    id: "panel-3",
    label: "TRANSFORMATION",
    headingLines: ["無駄を削ぎ落とし、", "人が本来の力を取り戻す。"],
    sub: "削減で生まれた時間と人材を\n適材適所に。それが真のDXだ。",
  },
];
---

<section
  id="hero-section"
  class="hero-container"
  data-base={base}
>
  <div class="hero-sticky" id="hero-sticky">
    <!-- Canvas背景 -->
    <canvas id="hero-canvas" class="hero-canvas"></canvas>

    <!-- 輝度連動オーバーレイ -->
    <div id="hero-overlay" class="hero-overlay"></div>

    <!-- 4幕コンテンツ -->
    <div class="hero-content">
      {acts.map((act) => {
        // 行ごとの累積文字数オフセットを計算（全行通しの delay 用）
        let charOffset = 0;
        return (
          <div class="hero-panel" id={act.id}>
            <p class="panel-label">{act.label}</p>
            <h2 class="panel-heading">
              {act.headingLines.map((line, lineIdx) => {
                const startOffset = charOffset;
                charOffset += line.length;
                return (
                  <>
                    {Array.from(line).map((ch, i) => (
                      <span class="char" style={`--i:${startOffset + i}`}>{ch}</span>
                    ))}
                    {lineIdx < act.headingLines.length - 1 && <br />}
                  </>
                );
              })}
            </h2>
            <p class="panel-sub">
              {act.sub.split("\n").map((line, i, arr) => (
                <>
                  {line}
                  {i < arr.length - 1 && <br />}
                </>
              ))}
            </p>
          </div>
        );
      })}

      <!-- 幕4: 朝 — ロゴ劇的登場 + CTA -->
      <div class="hero-panel hero-panel-final" id="panel-4">
        <div class="logo-wrapper">
          <span class="logo-glow" aria-hidden="true"></span>
          <img src={logoSymbol} alt="ANOM" class="panel-logo" />
        </div>
        <p class="panel-tagline">AUTONOMOUS + MINIMALISM</p>
        <div class="panel-divider"></div>
        <p class="panel-catch">無駄を削ぎ落とし、AIで自走する組織へ。</p>
        <div class="panel-buttons">
          <a href={withBase("/contact")} class="btn-primary">
            無料相談する
            <svg class="btn-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </a>
          <a href={withBase("/services")} class="btn-secondary">
            サービスを見る
            <svg class="btn-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- スクロールインジケーター -->
    <div id="scroll-indicator" class="scroll-indicator">
      <div class="scroll-mouse">
        <div class="scroll-dot"></div>
      </div>
      <p class="scroll-text">SCROLL</p>
    </div>
  </div>
</section>

<style>
  /* ===== コンテナ: 400vh でスクロール領域確保 ===== */
  .hero-container {
    height: 400vh;
    position: relative;
  }

  .hero-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    overflow: hidden;
  }

  .hero-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      /* 上部: ヘッダー視認性確保用の暗グラデーション */
      linear-gradient(to bottom, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0.15) 8%, transparent 16%),
      /* 中央: テキスト視認性のためのソフトな暗グロウ */
      radial-gradient(ellipse 80% 60% at 50% 55%, rgba(0,0,0,0.15) 0%, rgba(0,0,0,0.45) 100%),
      /* 下部: 全体を引き締める */
      linear-gradient(to bottom, transparent 60%, rgba(0,0,0,0.35) 100%);
    pointer-events: none;
    opacity: 0.1;
  }

  .hero-content {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
  }

  /* ===== 各幕パネル ===== */
  .hero-panel {
    position: absolute;
    text-align: center;
    padding: 0 1.5rem;
    max-width: 52rem;
    width: 100%;
    opacity: 0;
    transform: translateY(24px);
    will-change: opacity, transform;
    pointer-events: none;
  }

  /* active 時はクリック可能に */
  .hero-panel.active { pointer-events: auto; }

  /* ===== ラベル（最初に登場） ===== */
  .panel-label {
    font-size: 0.7rem;
    letter-spacing: 0.32em;
    font-weight: 600;
    color: rgba(255,255,255,0.7);
    text-transform: uppercase;
    text-shadow: 0 1px 6px rgba(0,0,0,0.6);
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.7s ease-out, transform 0.7s ease-out;
    transition-delay: 0.05s;
  }
  .hero-panel.active .panel-label {
    opacity: 1;
    transform: translateY(0);
  }

  /* ===== 見出し（文字単位で blur→clear） ===== */
  .panel-heading {
    margin-top: 1.25rem;
    font-size: clamp(1.75rem, 4vw, 2.875rem);
    font-weight: 700;
    line-height: 1.4;
    color: #ffffff;
    text-shadow: 0 2px 24px rgba(0,0,0,0.5);
  }

  .panel-heading .char {
    display: inline-block;
    opacity: 0;
    filter: blur(12px);
    transform: translateY(14px);
    transition:
      opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1),
      filter 0.7s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: calc(0.25s + var(--i) * 0.035s);
  }
  .hero-panel.active .panel-heading .char {
    opacity: 1;
    filter: blur(0);
    transform: translateY(0);
  }

  /* ===== サブコピー（最後に登場） ===== */
  .panel-sub {
    margin-top: 1.75rem;
    font-size: clamp(0.9375rem, 1.6vw, 1.0625rem);
    line-height: 1.95;
    color: rgba(255,255,255,0.85);
    text-shadow: 0 2px 12px rgba(0,0,0,0.7);
    opacity: 0;
    transform: translateY(14px);
    transition: opacity 0.8s ease-out, transform 0.8s ease-out;
    transition-delay: 0.85s;
  }
  .hero-panel.active .panel-sub {
    opacity: 1;
    transform: translateY(0);
  }

  /* ===== 幕4: 朝 — ロゴ劇的登場 ===== */
  .logo-wrapper {
    position: relative;
    display: inline-block;
    margin: 0 auto;
  }

  /* ロゴ背後のグロウ */
  .logo-glow {
    position: absolute;
    inset: -40%;
    z-index: -1;
    background: radial-gradient(closest-side, rgba(91,110,245,0.35), rgba(123,142,255,0.18) 45%, transparent 75%);
    filter: blur(20px);
    opacity: 0;
    transform: scale(0.6);
    transition: opacity 1.4s cubic-bezier(0.22, 1, 0.36, 1), transform 1.4s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: 0.1s;
  }
  .hero-panel.active .logo-glow {
    opacity: 1;
    transform: scale(1);
  }

  /* ロゴ画像 — 劇的に出現（scale + blur + translate） */
  .panel-logo {
    width: 6rem;
    height: 6rem;
    filter: invert(1) drop-shadow(0 6px 28px rgba(255,255,255,0.25));
    mix-blend-mode: screen;
    opacity: 0;
    transform: translateY(36px) scale(0.85);
    filter: invert(1) blur(20px) drop-shadow(0 6px 28px rgba(255,255,255,0.25));
    transition:
      opacity 0.9s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.9s cubic-bezier(0.16, 1, 0.3, 1),
      filter 0.9s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: 0.25s;
  }
  @media (min-width: 768px) {
    .panel-logo { width: 7.5rem; height: 7.5rem; }
  }
  .hero-panel.active .panel-logo {
    opacity: 1;
    transform: translateY(0) scale(1);
    filter: invert(1) blur(0) drop-shadow(0 6px 28px rgba(255,255,255,0.25));
  }

  .panel-tagline {
    margin-top: 1.5rem;
    font-size: 0.7rem;
    letter-spacing: 0.4em;
    font-weight: 300;
    color: rgba(255,255,255,0.55);
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.7s ease-out, transform 0.7s ease-out;
    transition-delay: 0.95s;
  }
  .hero-panel.active .panel-tagline {
    opacity: 1;
    transform: translateY(0);
  }

  .panel-divider {
    margin: 1.75rem auto;
    width: 0;
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(255,255,255,0.4), transparent);
    transition: width 0.9s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: 1.1s;
  }
  .hero-panel.active .panel-divider {
    width: 4rem;
  }

  .panel-catch {
    font-size: clamp(0.9375rem, 2vw, 1.125rem);
    font-weight: 500;
    color: rgba(255,255,255,0.85);
    text-shadow: 0 2px 12px rgba(0,0,0,0.45);
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.7s ease-out, transform 0.7s ease-out;
    transition-delay: 1.25s;
  }
  .hero-panel.active .panel-catch {
    opacity: 1;
    transform: translateY(0);
  }

  .panel-buttons {
    margin-top: 2.25rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.875rem;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.7s ease-out, transform 0.7s ease-out;
    transition-delay: 1.45s;
  }
  .hero-panel.active .panel-buttons {
    opacity: 1;
    transform: translateY(0);
  }

  @media (min-width: 640px) {
    .panel-buttons { flex-direction: row; justify-content: center; }
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 2rem;
    background: rgba(255,255,255,0.95);
    color: #0A0A0F;
    font-size: 0.875rem;
    font-weight: 600;
    border-radius: 0.5rem;
    text-decoration: none;
    box-shadow: 0 4px 20px rgba(0,0,0,0.25);
    transition: transform 0.25s, box-shadow 0.25s;
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 32px rgba(0,0,0,0.3);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 2rem;
    border: 1px solid rgba(255,255,255,0.28);
    color: rgba(255,255,255,0.75);
    font-size: 0.875rem;
    font-weight: 500;
    border-radius: 0.5rem;
    text-decoration: none;
    backdrop-filter: blur(4px);
    transition: transform 0.25s, border-color 0.25s, color 0.25s;
  }
  .btn-secondary:hover {
    transform: translateY(-2px);
    border-color: rgba(255,255,255,0.5);
    color: #ffffff;
  }

  .btn-icon { width: 1rem; height: 1rem; }

  /* ===== スクロールインジケーター ===== */
  .scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    z-index: 10;
    transition: opacity 0.4s;
  }

  .scroll-mouse {
    width: 1.375rem;
    height: 2.25rem;
    border: 1.5px solid rgba(255,255,255,0.25);
    border-radius: 9999px;
    display: flex;
    justify-content: center;
    padding-top: 0.35rem;
  }

  .scroll-dot {
    width: 0.2rem;
    height: 0.55rem;
    background: rgba(255,255,255,0.45);
    border-radius: 9999px;
    animation: scroll-bounce 1.6s ease-in-out infinite;
  }

  .scroll-text {
    font-size: 0.5rem;
    letter-spacing: 0.22em;
    color: rgba(255,255,255,0.28);
  }

  @keyframes scroll-bounce {
    0%, 100% { transform: translateY(0); opacity: 0.5; }
    50% { transform: translateY(5px); opacity: 1; }
  }
</style>

<script>
  const TOTAL_FRAMES = 60;
  const SCALE = 1.08;

  const section = document.getElementById('hero-section') as HTMLElement;
  const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement;
  const overlay = document.getElementById('hero-overlay') as HTMLElement;
  const indicator = document.getElementById('scroll-indicator') as HTMLElement;
  const ctx = canvas.getContext('2d')!;

  const base = (section?.dataset.base ?? '');
  const frames: HTMLImageElement[] = new Array(TOTAL_FRAMES);
  let currentIndex = -1;
  let rafId: number | null = null;

  function resizeCanvas() {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
    redraw();
  }

  function drawFrame(i: number) {
    const img = frames[i];
    if (!img || i === currentIndex) return;
    currentIndex = i;
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    ctx.drawImage(img, 0, 0, canvas.width * SCALE, canvas.height * SCALE);
  }

  function redraw() {
    if (currentIndex >= 0 && frames[currentIndex]) {
      const saved = currentIndex;
      currentIndex = -1;
      drawFrame(saved);
    }
  }

  function getProgress(): number {
    const rect = section.getBoundingClientRect();
    const total = section.offsetHeight - window.innerHeight;
    return Math.max(0, Math.min(1, -rect.top / total));
  }

  function overlayOpacity(fi: number): number {
    if (fi <= 10) return 0.05;
    if (fi <= 25) return 0.05 + (fi - 10) / 15 * 0.28;
    if (fi <= 45) return 0.33 + (fi - 25) / 20 * 0.12;
    return 0.45 + (fi - 45) / 14 * 0.05;
  }

  // パネルの表示タイミング（in: 出現範囲, out: 消失範囲）
  // active クラスは「ほぼ完全表示」状態のときだけ付与（一度発火したらフェードアウト中も維持）
  const panels = [
    { id: 'panel-1', in: [0.00, 0.04], out: [0.19, 0.24], activeRange: [0.02, 0.22] },
    { id: 'panel-2', in: [0.22, 0.27], out: [0.44, 0.49], activeRange: [0.25, 0.47] },
    { id: 'panel-3', in: [0.47, 0.52], out: [0.69, 0.74], activeRange: [0.50, 0.72] },
    { id: 'panel-4', in: [0.72, 0.78], out: null,         activeRange: [0.75, 1.10] },
  ] as const;

  function updatePanels(p: number) {
    panels.forEach(({ id, in: fi, out: fo, activeRange }) => {
      const el = document.getElementById(id) as HTMLElement;
      if (!el) return;

      // opacity と translateY 計算
      let opacity = 0;
      let ty = 20;
      const start = fi[0], peak = fi[1];
      const end = fo ? fo[1] : 1.0;
      const fadeOutStart = fo ? fo[0] : 999;

      if (p >= start && p <= end) {
        if (p < peak) {
          const t = (p - start) / (peak - start);
          opacity = t; ty = 20 * (1 - t);
        } else if (p < fadeOutStart) {
          opacity = 1; ty = 0;
        } else if (fo) {
          const t = (p - fo[0]) / (fo[1] - fo[0]);
          opacity = 1 - t; ty = -16 * t;
        }
      }

      el.style.opacity = String(Math.max(0, Math.min(1, opacity)));
      el.style.transform = `translateY(${ty}px)`;

      // active クラス（CSSアニメーション発火用）の付け外し
      const inActiveRange = p >= activeRange[0] && p <= activeRange[1];
      if (inActiveRange && !el.classList.contains('active')) {
        el.classList.add('active');
      } else if (!inActiveRange && el.classList.contains('active')) {
        el.classList.remove('active');
      }
    });
  }

  function updateIndicator(p: number) {
    const op = p < 0.04 ? 1 : Math.max(0, 1 - (p - 0.04) / 0.04);
    indicator.style.opacity = String(op);
  }

  function update() {
    const p = getProgress();
    const fi = Math.min(TOTAL_FRAMES - 1, Math.floor(p * TOTAL_FRAMES));
    drawFrame(fi);
    overlay.style.opacity = String(overlayOpacity(fi));
    updatePanels(p);
    updateIndicator(p);
  }

  function onScroll() {
    if (rafId) cancelAnimationFrame(rafId);
    rafId = requestAnimationFrame(update);
  }

  function preload() {
    for (let i = 0; i < TOTAL_FRAMES; i++) {
      const img = new Image();
      const num = String(i).padStart(3, '0');
      img.src = `${base}/hero-frames/frame_${num}.webp`;
      img.onload = () => {
        frames[i] = img;
        if (i === 0) { drawFrame(0); update(); }
      };
    }
  }

  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  resizeCanvas();
  window.addEventListener('resize', resizeCanvas, { passive: true });

  if (reduced) {
    const img = new Image();
    img.src = `${base}/hero-frames/frame_000.webp`;
    img.onload = () => { frames[0] = img; drawFrame(0); };
    section.style.height = '100vh';
    const p4 = document.getElementById('panel-4') as HTMLElement;
    if (p4) {
      p4.style.opacity = '1';
      p4.style.transform = 'translateY(0)';
      p4.classList.add('active');
    }
    indicator.style.display = 'none';
  } else {
    window.addEventListener('scroll', onScroll, { passive: true });
    preload();
    update();
  }
</script>
