---
// ヒーローセクション — グラデーション背景 + 幾何学パターンアニメーション
import { withBase } from "../data/navigation";
---

<section class="relative flex min-h-screen items-center justify-center overflow-hidden bg-gradient-to-br from-navy via-navy-dark to-dark">
  <!-- 背景の幾何学パターンアニメーション -->
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <!-- 浮遊する幾何学図形 -->
    <div class="geo geo-1"></div>
    <div class="geo geo-2"></div>
    <div class="geo geo-3"></div>
    <div class="geo geo-4"></div>
    <div class="geo geo-5"></div>
    <!-- グラデーションオーバーレイ -->
    <div class="absolute inset-0 bg-gradient-to-t from-dark/40 via-transparent to-navy/20"></div>
  </div>

  <!-- コンテンツ -->
  <div class="relative z-10 mx-auto max-w-4xl px-4 text-center">
    <!-- メインタイトル -->
    <h1 class="text-5xl font-bold tracking-tight text-white md:text-7xl lg:text-8xl">
      ANOM
    </h1>

    <!-- タグライン -->
    <p class="mt-4 text-xs tracking-[0.3em] font-light text-white/50 md:text-sm md:tracking-[0.4em]">
      AUTONOMOUS + MINIMALISM
    </p>

    <!-- キャッチコピー -->
    <p class="mt-10 text-lg leading-relaxed font-medium text-white/90 md:text-2xl md:leading-relaxed">
      無駄を削ぎ落とし、<br class="md:hidden" />AIで自走する組織へ。
    </p>

    <!-- サブコピー -->
    <p class="mt-4 text-sm text-white/60 md:text-base">
      秋田の中小企業のDX・AI導入を、戦略から定着まで伴走支援。
    </p>

    <!-- CTAボタン -->
    <div class="mt-12 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
      <a
        href={withBase("/contact")}
        class="group relative inline-flex items-center rounded-md bg-white px-8 py-3.5 text-sm font-semibold text-navy shadow-lg transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_8px_30px_rgba(255,255,255,0.15)]"
      >
        無料相談する
        <!-- ホバー時のglow -->
        <span class="absolute inset-0 -z-10 rounded-md bg-white opacity-0 blur-xl transition-opacity duration-300 group-hover:opacity-30"></span>
      </a>
      <a
        href={withBase("/services")}
        class="inline-flex items-center rounded-md border border-white/25 px-8 py-3.5 text-sm font-medium text-white/80 transition-all duration-300 hover:-translate-y-0.5 hover:border-white/50 hover:text-white"
      >
        サービスを見る
      </a>
    </div>
  </div>

  <!-- スクロールインジケーター -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2">
    <div class="flex h-8 w-5 items-start justify-center rounded-full border border-white/30 p-1">
      <div class="h-2 w-1 animate-bounce rounded-full bg-white/60"></div>
    </div>
  </div>
</section>

<style>
  /* 幾何学図形の共通スタイル */
  .geo {
    position: absolute;
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 2px;
    animation: float linear infinite;
  }

  .geo-1 {
    width: 200px;
    height: 200px;
    top: 10%;
    left: 5%;
    transform: rotate(15deg);
    animation-duration: 25s;
  }

  .geo-2 {
    width: 120px;
    height: 120px;
    top: 60%;
    right: 10%;
    transform: rotate(-30deg);
    animation-duration: 20s;
    animation-delay: -5s;
  }

  .geo-3 {
    width: 80px;
    height: 80px;
    top: 30%;
    right: 25%;
    border-radius: 50%;
    animation-duration: 30s;
    animation-delay: -10s;
  }

  .geo-4 {
    width: 150px;
    height: 150px;
    bottom: 20%;
    left: 15%;
    transform: rotate(45deg);
    animation-duration: 22s;
    animation-delay: -8s;
  }

  .geo-5 {
    width: 60px;
    height: 60px;
    top: 15%;
    right: 15%;
    border-radius: 50%;
    animation-duration: 18s;
    animation-delay: -3s;
  }

  /* 浮遊アニメーション */
  @keyframes float {
    0% {
      transform: translateY(0) rotate(0deg);
      opacity: 0.3;
    }
    25% {
      opacity: 0.6;
    }
    50% {
      transform: translateY(-30px) rotate(180deg);
      opacity: 0.3;
    }
    75% {
      opacity: 0.6;
    }
    100% {
      transform: translateY(0) rotate(360deg);
      opacity: 0.3;
    }
  }
</style>
